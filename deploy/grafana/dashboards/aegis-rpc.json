      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(aegis_cache_requests_total{result=\"hit\"}[1m])) / sum(rate(aegis_cache_requests_total[1m]))",
          "legendFormat": "hit rate",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
